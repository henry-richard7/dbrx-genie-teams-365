# Microsoft App Registration Details
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=your_tenant_id_here
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=your_app_client_id_here
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=your_app_client_secret_here

# Server Settings
PORT=3978
DEBUG=true

# Databricks Genie Settings
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
ENABLE_CHARTS=active

# Databricks Credentials (if not using Entra ID groups)
DATABRICKS_TOKEN=your_personal_access_token_here
DATABRICKS_CLIENT_ID=your_oauth_client_id_here
DATABRICKS_CLIENT_SECRET=your_oauth_client_secret_here

# OpenAI-Compatible LLM Settings (e.g., Databricks, OpenAI, vLLM, Ollama)
OPENAI_MODEL_NAME=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_api_key_here

# Optional: Database Connection String (Defaults to local SQLite)
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
